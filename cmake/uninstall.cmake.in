if(NOT DEFINED INSTALL_MANIFEST OR INSTALL_MANIFEST STREQUAL "")
    message(FATAL_ERROR "INSTALL_MANIFEST was not provided")
endif()

if(NOT EXISTS "${INSTALL_MANIFEST}")
    message(FATAL_ERROR "Install manifest not found: ${INSTALL_MANIFEST}")
endif()

file(STRINGS "${INSTALL_MANIFEST}" installed_files)

foreach(installed_file IN LISTS installed_files)
    if(installed_file STREQUAL "")
        continue()
    endif()

    if(EXISTS "${installed_file}" OR IS_SYMLINK "${installed_file}")
        file(REMOVE "${installed_file}")
        message(STATUS "Removed ${installed_file}")
    else()
        message(STATUS "Already absent ${installed_file}")
    endif()
endforeach()
